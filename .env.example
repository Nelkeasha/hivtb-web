# Copy this file to .env.local for local development.
# Next.js automatically loads .env.local and exposes NEXT_PUBLIC_* vars to the browser.

# Base URL of the Spring Boot backend API.
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8080
# Production (deployed backend on Render):
# NEXT_PUBLIC_API_URL=https://hivtb-rw-api.onrender.com
